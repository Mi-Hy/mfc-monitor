[Unit]
Description=System controller Service
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/mfc-validation/controller/controller.py
WorkingDirectory=/home/pi/mfc-validation/controller
Restart=always
RestartSec=30
User=pi
Environment=DISPLAY=:0

[Install]
WantedBy=multi-user.target